# Product Hunt Mailer - Environment Variables
# Copy this file to .env and fill in your API keys

# Gemini API Key (Get one at: https://aistudio.google.com/apikey)
# GEMINI_API_KEY=your_gemini_api_key_here

# Resend API Key (Get one at: https://resend.com)
# RESEND_API_KEY=your_resend_api_key_here

# Product Hunt Developer Token (Get one at: https://www.producthunt.com/v2/oauth/applications)
# PRODUCT_HUNT_TOKEN=your_product_hunt_token_here
